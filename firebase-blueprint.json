{
  "entities": {
    "Driver": {
      "title": "Driver",
      "description": "Information about a driver using the system.",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "currentLat": { "type": "number" },
        "currentLong": { "type": "number" },
        "accountStatus": { "type": "string", "enum": ["Active", "Suspended", "Banned"] }
      },
      "required": ["driverId", "name", "email", "phoneNumber"]
    },
    "ParkingLocation": {
      "title": "Parking Location",
      "description": "Details about a parking facility.",
      "type": "object",
      "properties": {
        "facilityId": { "type": "string" },
        "facilityName": { "type": "string" },
        "address": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Verified", "Full", "Suspended"] },
        "totalSpaces": { "type": "integer" },
        "availableSpaces": { "type": "integer" },
        "pricePerHour": { "type": "number" }
      },
      "required": ["facilityId", "facilityName", "address", "latitude", "longitude", "status", "totalSpaces", "availableSpaces", "pricePerHour"]
    },
    "ParkingAdministrator": {
      "title": "Parking Administrator",
      "description": "Admin for a specific parking facility.",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "facilityID": { "type": "string" }
      },
      "required": ["adminId", "name", "email", "facilityID"]
    },
    "SystemAdministrator": {
      "title": "System Administrator",
      "description": "Global administrator for the ParkWise system.",
      "type": "object",
      "properties": {
        "sysAdminId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "adminActionLog": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["sysAdminId", "name", "email"]
    },
    "User": {
      "title": "User",
      "description": "Common user profile for authentication and role management.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["driver", "parking_admin", "sys_admin"] },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "User" },
      "description": "User profiles and roles."
    },
    "/parkingLocations/{facilityId}": {
      "schema": { "$ref": "ParkingLocation" },
      "description": "Parking facility data."
    },
    "/drivers/{driverId}": {
      "schema": { "$ref": "Driver" },
      "description": "Driver-specific data."
    },
    "/parkingAdmins/{adminId}": {
      "schema": { "$ref": "ParkingAdministrator" },
      "description": "Parking administrator data."
    },
    "/systemAdmins/{sysAdminId}": {
      "schema": { "$ref": "SystemAdministrator" },
      "description": "System administrator data."
    }
  }
}
